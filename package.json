{
  "name": "massdriver",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite dev --host 0.0.0.0",
    "mock:dev": "vite dev --host 0.0.0.0 --open /mock/mockup.html",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate-pwa-assets": "pwa-assets-generator"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@skeletonlabs/skeleton-svelte": "^4.12.1",
    "@sveltejs/adapter-auto": "^4.0.0",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vite-pwa/sveltekit": "^1.1.0",
    "eslint": "^10.0.3",
    "eslint-plugin-svelte": "^3.15.2",
    "globals": "^17.4.0",
    "svelte": "^5.53.11",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.2.1",
    "tslib": "^2.8.1",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@atproto/api": "^0.19.3",
    "@types/uuid": "^10.0.0",
    "nostr-tools": "^2.23.3",
    "uuid": "^11.0.0"
  },
  "overrides": {
    "cookie": "^1.1.1",
    "flatted": "^3.4.2",
    "@rollup/plugin-terser": "^1.0.0"
  }
}
